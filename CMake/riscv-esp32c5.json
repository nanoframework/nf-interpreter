{
    "version": 4,
    "include": [
        "base.json"
    ],
    "configurePresets": [
        {
            "name": "riscv-esp32c5-preset",
            "description": "Preset for ESP32-C5 series",
            "inherits": "general-preset",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": {
                    "type": "FILEPATH",
                    "value": "${sourceDir}/CMake/toolchain.riscv32-esp32c5-elf.cmake"
                },
                "NF_INTEROP_ASSEMBLIES": null
            }
        }
    ]
}
