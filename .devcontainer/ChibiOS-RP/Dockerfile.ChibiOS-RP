# Pre-built image is not yet available for ChibiOS-RP.
# Use Dockerfile.ChibiOS-RP.SRC to build from source.
# Once published, replace this line with the image reference, e.g.:
# FROM ghcr.io/nanoframework/dev-container-chibios-rp:latest
FROM ubuntu:latest
RUN echo "No pre-built ChibiOS-RP container image available yet." && \
    echo "Please switch to Dockerfile.ChibiOS-RP.SRC in devcontainer.json." && \
    exit 1
