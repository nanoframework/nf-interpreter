/////////////////////////////////////////////////////////////////////////////////////////
// The following addresses and sizes should be filled in according to the SoC data-sheet
// they also must be coherent with what's in the linker file for nanoBooter and nanoCLR

// RAM base address (RP2350: 520 KB SRAM total, main 512 KB bank)
#define RAM1_MEMORY_StartAddress        ((uint32_t)0x20000000)
// RAM size (512 KB main SRAM)
#define RAM1_MEMORY_Size                ((uint32_t)0x00080000)

// FLASH base address (RP2350: XIP flash starts at 0x10000000)
#define FLASH1_MEMORY_StartAddress      ((uint32_t)0x10000000)
// FLASH size (4 MB on standard Pico2 board)
#define FLASH1_MEMORY_Size              ((uint32_t)0x00400000)

/////////////////////////////////////////////////////////////////////////////////////////

//////////////////////////////////////////////
// set Wire Protocol packet size
// valid sizes are 1024, 512, 256, 128
// check Monitor_Ping_Source_Flags enum
#define WP_PACKET_SIZE                  512U
//////////////////////////////////////////////

//////////////////////////////////////////////
#define TARGETNAMESTRING "@TARGET_NAME@"
#define PLATFORMNAMESTRING "RP2350"
//////////////////////////////////////////////

//////////////////////////////////////////////
// RP2350 has larger SRAM than RP2040, but still constrained compared to larger MCUs
// set define to signal build system that this target is RAM constrained
#define TARGET_RAM_CONSTRAINED
