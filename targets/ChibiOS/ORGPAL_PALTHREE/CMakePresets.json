{
    "version": 4,
    "include": [
        "../../../CMake/arm-gcc.json",
        "../../../config/user-tools-repos.json",
        "../../../config/user-prefs.json"
    ],
    "configurePresets": [
        {
            "name": "ORGPAL_PALTHREE",
            "inherits": [
                "arm-gcc-cortex-preset",
                "user-tools-repos",
                "user-prefs"
            ],
            "hidden": false,
            "cacheVariables": {
                "NF_TARGET_DEFCONFIG": "targets/ChibiOS/ORGPAL_PALTHREE/defconfig",
                "NF_MCUBOOT_SLOT_SIZE": "0xF0000",
                "NF_MCUBOOT_SIGNING_KEY": "${sourceDir}/MCUboot/keys/dev-signing-key.pem"
            }
        }
    ],
    "buildPresets": [
        {
            "inherits": "base-user",
            "name": "ORGPAL_PALTHREE",
            "displayName": "ORGPAL_PALTHREE",
            "configurePreset": "ORGPAL_PALTHREE"
        }
    ]
}
