{
    "version": 4,
    "include": [
        "../../../CMake/arm-gcc.json",
        "../../../config/user-tools-repos.json",
        "../../../config/user-prefs.json"
    ],
    "configurePresets": [
        {
            "name": "RP_PICO_W_RP2040",
            "inherits": [
                "arm-gcc-cortex-preset",
                "user-tools-repos",
                "user-prefs"
            ],
            "hidden": false,
            "cacheVariables": {
                "TARGET_BOARD": "${presetName}",
                "TARGET_SERIES": "RP2040",
                "RTOS": "ChibiOS",
                "CHIBIOS_CONTRIB_REQUIRED": "OFF",
                "STM32_CUBE_PACKAGE_REQUIRED": "OFF",
                "SUPPORT_ANY_BASE_CONVERSION": "OFF",
                "NF_FEATURE_DEBUGGER": "ON",
                "NF_FEATURE_RTC": "ON",
                "NF_FEATURE_HAS_CONFIG_BLOCK": "ON",
                "NF_PLATFORM_NO_CLR_TRACE": "OFF",
                "NF_FEATURE_LIGHT_MATH": "ON",
                "SWO_OUTPUT": "OFF",
                "NF_BUILD_RTM": "OFF",
                "USE_RNG": "OFF",
                "API_System.Device.Gpio": "ON",
                "API_System.Device.Spi": "ON",
                "API_System.Device.I2c": "ON",
                "API_System.Device.Pwm": "ON",
                "API_System.Device.Adc": "ON",
                "API_System.Net": "ON",
                "API_System.Device.Wifi": "ON",
                "NF_SECURITY_MBEDTLS": "ON",
                "API_nanoFramework.System.Text": "ON",
                "API_nanoFramework.ResourceManager": "ON",
                "API_nanoFramework.System.Collections": "ON",
                "TARGET_HAS_WIFI": "ON",
                "NF_FEATURE_HAS_ACCESSIBLE_STORAGE": "OFF",
                "NF_FEATURE_USE_LITTLEFS": "OFF",
                "API_System.IO.FileSystem": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "inherits": "base-user",
            "name": "RP_PICO_W_RP2040",
            "displayName": "RP_PICO_W_RP2040",
            "configurePreset": "RP_PICO_W_RP2040"
        }
    ]
}
